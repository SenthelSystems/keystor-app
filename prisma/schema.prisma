generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                             String               @id @default(cuid())
  name                           String
  slug                           String               @unique
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  stripeCustomerId               String?              @unique
  stripePriceId                  String?
  stripeSubscriptionId           String?              @unique
  subscriptionCancelAtPeriodEnd  Boolean              @default(false)
  subscriptionCanceledAt         DateTime?
  subscriptionCurrentPeriodEnd   DateTime?
  subscriptionCurrentPeriodStart DateTime?
  subscriptionStatus             BillingStatus?
  billingEvents                  BillingEvent[]
  invites                        Invite[]
  leases                         Lease[]
  maintenanceRequests            MaintenanceRequest[]
  properties                     Property[]
  serviceAttachments             ServiceAttachment[]
  supportTickets                 SupportTicket[]
  units                          Unit[]
  users                          User[]
}

model BillingEvent {
  id             String       @id @default(cuid())
  organizationId String
  stripeEventId  String       @unique
  eventType      String
  payload        Json?
  processedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([eventType])
  @@index([processedAt])
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String?
  passwordHash        String
  role                UserRole
  organizationId      String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  tenantLeases        Lease[]              @relation("TenantLeases")
  maintenanceRequests MaintenanceRequest[] @relation("TenantMaintenance")
  uploadedAttachments ServiceAttachment[]
  supportTickets      SupportTicket[]
  tenantProfile       TenantProfile?
  organization        Organization         @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model TenantProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  phone            String?
  emergencyContact String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id])
}

model Property {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  type           String
  address        String
  city           String
  state          String
  postalCode     String
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  units          Unit[]

  @@index([organizationId])
}

model Unit {
  id                  String               @id @default(cuid())
  organizationId      String
  propertyId          String
  label               String
  category            String
  status              UnitStatus           @default(VACANT)
  baseRentCents       Int
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[] @relation("UnitMaintenance")
  organization        Organization         @relation(fields: [organizationId], references: [id])
  property            Property             @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([propertyId])
}

model MaintenanceRequest {
  id             String              @id @default(cuid())
  organizationId String
  tenantId       String
  unitId         String?
  title          String
  description    String
  priority       String
  status         MaintenanceStatus   @default(OPEN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id])
  tenant         User                @relation("TenantMaintenance", fields: [tenantId], references: [id])
  unit           Unit?               @relation("UnitMaintenance", fields: [unitId], references: [id])
  attachments    ServiceAttachment[]

  @@index([organizationId])
  @@index([tenantId])
  @@index([unitId])
}

model SupportTicket {
  id             String                @id @default(cuid())
  organizationId String
  userId         String
  category       SupportTicketCategory @default(OTHER)
  subject        String
  message        String
  status         SupportTicketStatus   @default(OPEN)
  pageUrl        String?
  userAgent      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  organization   Organization          @relation(fields: [organizationId], references: [id])
  user           User                  @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([status])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String
  entityType     String
  entityId       String
  action         AuditAction
  metadata       Json?
  createdAt      DateTime    @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
}

model Lease {
  id             String       @id @default(cuid())
  organizationId String
  unitId         String
  tenantId       String
  startDate      DateTime
  endDate        DateTime?
  rentCents      Int
  status         LeaseStatus  @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  tenant         User         @relation("TenantLeases", fields: [tenantId], references: [id])
  unit           Unit         @relation(fields: [unitId], references: [id])

  @@index([organizationId])
  @@index([unitId])
  @@index([tenantId])
  @@index([status])
}

model Invite {
  id             String        @id @default(cuid())
  organizationId String?
  email          String
  name           String?
  role           InviteRole    @default(TENANT)
  status         InviteStatus  @default(PENDING)
  token          String        @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([email])
  @@index([status])
}

model ServiceAttachment {
  id               String             @id @default(cuid())
  organizationId   String
  requestId        String
  uploadedByUserId String
  kind             AttachmentKind
  mimeType         String
  sizeBytes        Int
  storagePath      String
  createdAt        DateTime           @default(now())
  organization     Organization       @relation(fields: [organizationId], references: [id])
  request          MaintenanceRequest @relation(fields: [requestId], references: [id])
  uploadedByUser   User               @relation(fields: [uploadedByUserId], references: [id])

  @@index([organizationId])
  @@index([requestId])
  @@index([uploadedByUserId])
}

enum UserRole {
  OWNER
  TENANT
}

enum UnitStatus {
  VACANT
  OCCUPIED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETE
  CANCELLED
}

enum InviteRole {
  TENANT
  OWNER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  INVALIDATED
}

enum SupportTicketCategory {
  BUG
  FEATURE
  BILLING
  SECURITY
  OTHER
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

enum LeaseStatus {
  ACTIVE
  ENDED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AttachmentKind {
  IMAGE
  VIDEO
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
}
